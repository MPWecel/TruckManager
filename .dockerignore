# Keep the Docker build context lean and reproducible.

# .NET build outputs
**/bin/
**/obj/
**/*.user

# IDE / editor
.vs/
.vscode/
.idea/

# Local secrets / env
**/appsettings.Development.json
**/appsettings.Local.json
**/.env
**/secrets.json

# Docker files copied via COPY only — exclude from "copy everything" patterns
**/Dockerfile
**/.dockerignore

# Tests are not needed inside the API image
tests/

# Misc
**/.git/
**/.gitignore
**/*.log
**/TestResults/
**/coverage/
